{
  "multipart": [
    {
      "apply": {
        "model": "hbmntm:block/red_cable_classic_center"
      }
    },
    {
      "when": {
        "north": true
      },
      "apply": {
        "model": "hbmntm:block/red_cable_classic_side"
      }
    },
    {
      "when": {
        "east": true
      },
      "apply": {
        "model": "hbmntm:block/red_cable_classic_side",
        "y": 90
      }
    },
    {
      "when": {
        "south": true
      },
      "apply": {
        "model": "hbmntm:block/red_cable_classic_side",
        "y": 180
      }
    },
    {
      "when": {
        "west": true
      },
      "apply": {
        "model": "hbmntm:block/red_cable_classic_side",
        "y": 270
      }
    },
    {
      "when": {
        "up": true
      },
      "apply": {
        "model": "hbmntm:block/red_cable_classic_side",
        "x": 270
      }
    },
    {
      "when": {
        "down": true
      },
      "apply": {
        "model": "hbmntm:block/red_cable_classic_side",
        "x": 90
      }
    }
  ]
}
